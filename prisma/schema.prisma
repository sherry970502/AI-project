generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── AUTH ──────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── USER ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
}

// ── PROJECT ───────────────────────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String
  status       String        @default("PLANNING")
  currentStage String        @default("calibrate")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  stages            PipelineStage[]
  execTasks         ExecTask[]
  lockedDocs        LockedDocument[]
  knowledgeEntries  KnowledgeEntry[]
  conciergeMessages ConciergeMessage[]
  mindMap           MindMap?
}

// ── PIPELINE STAGE ────────────────────────────────────────────────────────

model PipelineStage {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageKey      String
  status        String   @default("IDLE")
  lockedContent String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  messages      Message[]

  @@unique([projectId, stageKey])
}

// ── EXEC TASK ─────────────────────────────────────────────────────────────

model ExecTask {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  outputDesc    String
  order         Int
  status        String   @default("IDLE")
  marker        String?  // NEW | ADJUSTED | NEEDS_RERUN
  lockedContent String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  messages      Message[]
  actionItems   ActionItem[]

  @@index([projectId, order])
}

// ── ACTION ITEM ────────────────────────────────────────────────────────────

model ActionItem {
  id         String   @id @default(cuid())
  execTaskId String
  execTask   ExecTask @relation(fields: [execTaskId], references: [id], onDelete: Cascade)
  content    String
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([execTaskId])
}

// ── MESSAGE ───────────────────────────────────────────────────────────────

model Message {
  id         String         @id @default(cuid())
  stageId    String?
  stage      PipelineStage? @relation(fields: [stageId], references: [id], onDelete: Cascade)
  execTaskId String?
  execTask   ExecTask?      @relation(fields: [execTaskId], references: [id], onDelete: Cascade)
  role       String
  content    String
  createdAt  DateTime       @default(now())
}

// ── LOCKED DOCUMENT ───────────────────────────────────────────────────────

model LockedDocument {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  sourceKey String
  content   String
  order     Int
  color     String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, sourceKey, version])
}

// ── KNOWLEDGE ENTRY ───────────────────────────────────────────────────────

model KnowledgeEntry {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // NOTE | FILE
  title     String
  content   String
  fileName  String?
  createdAt DateTime @default(now())
}

// ── MIND MAP ──────────────────────────────────────────────────────────────

model MindMap {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes       String   // JSON tree
  priorities  String   @default("{}")
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── CONCIERGE MESSAGE ─────────────────────────────────────────────────────

model ConciergeMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String   // USER | ASSISTANT
  content   String
  createdAt DateTime @default(now())
}
